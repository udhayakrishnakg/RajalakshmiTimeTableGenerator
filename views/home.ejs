<div class="container py-5 my-3">
  <div class="row justify-content-center">
    <!-- Generation Panel -->
    <div class="col-lg-6 col-md-8">
      <div class="card card-custom border-0 shadow-lg overflow-hidden mb-5">
        <div class="card-header bg-charcoal text-white py-4 px-4 border-0">
          <h2 class="font-display fw-bold mb-1 fs-3">Generate New Timetable</h2>
          <p class="text-secondary-light text-sm mb-0">Select your parameters to begin designing the schedule.</p>
        </div>
        <div class="card-body p-4 bg-white">
          <form action="/select" method="GET" id="start-form">
            <div class="mb-4">
              <label for="department" class="form-label font-sans fw-semibold text-charcoal">Department</label>
              <select name="department" id="department" class="form-select form-select-lg border-secondary-subtle" required>
                <option value="" disabled selected>-- Select Department --</option>
                <% departments.forEach(dept => { %>
                  <option value="<%= dept %>"><%= dept %></option>
                <% }) %>
              </select>
            </div>
            
            <div class="mb-4">
              <label for="semester" class="form-label font-sans fw-semibold text-charcoal">Semester</label>
              <select name="semester" id="semester" class="form-select form-select-lg border-secondary-subtle" required>
                <option value="" disabled selected>-- Select Semester --</option>
                <% semesters.forEach(sem => { %>
                  <option value="<%= sem %>">Semester <%= sem %></option>
                <% }) %>
              </select>
            </div>

            <div class="d-grid pt-2">
              <button type="submit" class="btn btn-teal btn-lg text-white font-sans fw-semibold d-flex align-items-center justify-content-center">
                <span>Continue to Timetable</span>
                <i class="bi bi-arrow-right-short ms-2 fs-4"></i>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Saved Timetables Section -->
  <div class="row justify-content-center mt-4">
    <div class="col-lg-10">
      <div class="card card-custom border-0 shadow-sm bg-white p-4">
        <div class="d-flex align-items-center justify-content-between mb-4 pb-2 border-bottom border-light">
          <div class="d-flex align-items-center">
            <i class="bi bi-folder-check text-teal fs-3 me-2"></i>
            <h3 class="font-display fw-bold text-charcoal mb-0 fs-4">Load Saved Timetables</h3>
          </div>
          <span class="badge bg-charcoal font-mono px-3 py-2 text-xs"><%= savedTimetables.length %> Saved</span>
        </div>

        <% if (savedTimetables.length === 0) { %>
          <div class="text-center py-5">
            <i class="bi bi-journal-x text-muted fs-1 mb-3 d-block"></i>
            <h5 class="text-charcoal fw-semibold">No Saved Timetables</h5>
            <p class="text-muted text-sm mb-0">Use the selection form above to generate your first timetable and save it!</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr class="table-light">
                  <th scope="col" class="font-sans fw-semibold text-charcoal py-3">Department</th>
                  <th scope="col" class="font-sans fw-semibold text-charcoal py-3 text-center">Semester</th>
                  <th scope="col" class="font-sans fw-semibold text-charcoal py-3 text-center">Theory Classes</th>
                  <th scope="col" class="font-sans fw-semibold text-charcoal py-3 text-center">Lab Classes</th>
                  <th scope="col" class="font-sans fw-semibold text-charcoal py-3">Saved At</th>
                  <th scope="col" class="font-sans fw-semibold text-charcoal py-3 text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% savedTimetables.forEach(t => { %>
                  <tr id="row-<%= t.id %>">
                    <td>
                      <div class="fw-semibold text-charcoal"><%= t.department %></div>
                    </td>
                    <td class="text-center">
                      <span class="badge bg-secondary-subtle text-charcoal font-sans px-2.5 py-1.5 rounded">
                        Sem <%= t.semester %>
                      </span>
                    </td>
                    <td class="text-center font-mono text-sm text-muted"><%= t.selectedTheoryCount %></td>
                    <td class="text-center font-mono text-sm text-muted"><%= t.selectedLabsCount %></td>
                    <td>
                      <small class="text-muted font-mono">
                        <%= new Date(t.createdAt).toLocaleDateString() %> <%= new Date(t.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                      </small>
                    </td>
                    <td class="text-end">
                      <div class="d-inline-flex gap-2">
                        <a href="/select?department=<%= encodeURIComponent(t.department) %>&semester=<%= t.semester %>&savedId=<%= t.id %>" 
                           class="btn btn-outline-teal btn-sm fw-semibold d-flex align-items-center">
                          <i class="bi bi-box-arrow-in-right me-1"></i> Restore
                        </a>
                        <button class="btn btn-outline-danger btn-sm" onclick="deleteSavedTimetable('<%= t.id %>')" title="Delete Save">
                          <i class="bi bi-trash"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
async function deleteSavedTimetable(id) {
  if (!confirm('Are you sure you want to delete this saved timetable?')) return;
  
  try {
    const res = await fetch(`/save/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) {
      const row = document.getElementById(`row-${id}`);
      if (row) {
        row.style.opacity = '0';
        setTimeout(() => {
          row.remove();
          // Reload if no rows are left to display empty state
          if (document.querySelectorAll('tbody tr').length === 0) {
            window.location.reload();
          }
        }, 300);
      }
    } else {
      alert('Failed to delete: ' + (data.error || 'Unknown error'));
    }
  } catch (err) {
    alert('Error occurred while deleting: ' + err.message);
  }
}
</script>
