{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "app.js"
    },
    {
      "src": "^/select(?:/.*)?$",
      "dest": "app.js"
    },
    {
      "src": "^/save(?:/.*)?$",
      "dest": "app.js"
    },
    {
      "src": "^/export(?:/.*)?$",
      "dest": "app.js"
    }
  ]
}
